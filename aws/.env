# aws/.env - Default non-secret configuration for aws/setup.sh
# - Loaded automatically by aws/setup.sh unless ENV_FILE points to another file.
# - Keep secrets out of this file; the setup script prompts for secret values and
#   stores them in AWS Secrets Manager.

# Required AWS deployment configuration
AWS_REGION=us-west-2
AWS_ENV=sandbox
AWS_PROJECT_ID=uh-groupings-api

# Display name used in script output
PROJECT_NAME="UH Groupings API"

# Network configuration
# If left blank or replaced with placeholders, aws/setup.sh will prompt.
VPC_ID=vpc-xxxxx
SUBNET_IDS=subnet-xxxxx,subnet-yyyyy

# ECS configuration
DESIRED_COUNT=1

# GitHub Enterprise and CodePipeline configuration
GITHUB_ENTERPRISE_URL=https://github.com/uhawaii-system-its-ti-iam
GITHUB_OWNER=uhawaii-system-its-ti-iam
GITHUB_REPO=uh-groupings-api
GITHUB_BRANCH=dev-mhodges-2203
GITHUB_CONNECTION_ARN=arn:aws:codestar-connections:us-west-2:123456789012:connection/xxxxxx
